{
  "family": "devcollab-backend-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::654481053677:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "devcollab-backend",
      "image": "654481053677.dkr.ecr.us-east-1.amazonaws.com/devcollab-backend:v9",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 5000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "PORT", "value": "5000" },
        { "name": "DATABASE_URL", "value": "postgresql://postgres:0900581Name!@devcollab-db.cqhyiowwkf2r.us-east-1.rds.amazonaws.com:5432/devcollab" },
        { "name": "JWT_SECRET", "value": "your_jwt_secret" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/devcollab",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "backend"
        }
      }
    }
  ]
}
